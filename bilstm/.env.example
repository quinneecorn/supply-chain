# Data: csv (local) or supabase
DATA_SOURCE=csv
CSV_PATH=final_merged_data.csv
LABEL_MODE=4class

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key
SUPABASE_TABLE=NLP_copy_test
SUPABASE_SENTENCE_COL=masked_sentence
SUPABASE_LABEL_COL=relation_id

# Training
BATCH_SIZE=64
LEARNING_RATE=0.0005
EPOCHS=50
MIN_EPOCHS=15
EARLY_STOP_PATIENCE=10
# Imbalanced preset
USE_FOCAL_LOSS=true
USE_CLASS_WEIGHTS=true
USE_WEIGHTED_SAMPLER=false
CLASS_WEIGHT_POWER=0.5
MAX_CLASS_WEIGHT=3.0
EARLY_STOP_METRIC=macro_f1
TOP_K_CHECKPOINTS=3
CHECKPOINT_DIR=checkpoints
NUM_WORKERS=4
MAX_SEQ_LEN=128
EMBED_DIM=256
HIDDEN_DIM=384
NUM_LAYERS=2
DROPOUT=0.4
WEIGHT_DECAY=0.0001
VAL_RATIO=0.15
RANDOM_SEED=42

# Paths
MODEL_SAVE_PATH=checkpoints/bilstm_relation.pt